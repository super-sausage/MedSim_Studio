# ============================================
# CT Simulator - Environment Configuration
# ============================================

# ---- Frontend ----
# In Docker builds keep this on the frontend proxy path.
VITE_API_BASE_URL=/api/v1
VITE_APP_TITLE=CT Simulator

# ---- Docker Build Mirrors (optional) ----
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=
PIP_TRUSTED_HOST=
APT_MIRROR=

# ---- Backend ----
BACKEND_APP_NAME=CT Simulator API
BACKEND_DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ct_simulator
POSTGRES_USER=ctuser
POSTGRES_PASSWORD=ctpass123
DATABASE_URL=postgresql://ctuser:ctpass123@postgres:5432/ct_simulator

# ---- Storage (MinIO) ----
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=dicom-studies
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ---- AI Services ----
AI_MONAI_ENABLED=false
AI_MODEL_PATH=/app/ai-models
AI_DEVICE=cpu

# ---- Simulation ----
SIMULATION_DEFAULT_SEED=42
SIMULATION_MAX_LESIONS=50
SIMULATION_VOXEL_SIZE=0.5

# ---- Volume Rendering ----
RENDERING_CACHE_SIZE=512
RENDERING_QUALITY=high

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
